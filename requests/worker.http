# Worker API requests for ZinTrust
# Set WORKER_API_URL to your worker service base (default localhost:3000)

@workerName = example-worker
@version = 1.0.0

@jobId = 12345

@pluginId = example-queue

@queueName = default

@regionId = us-east-1

@spanId = abcdef123456

@WORKER_API_URL = http://localhost:7777


### List all workers
### @returns Array of workers
###
GET {{WORKER_API_URL}}/api/workers
Accept: application/json


###  Create worker
###
### Create a new worker instance
### @param name - Worker name (required)
### @param queueName - Queue name (required)
### @param processor - Job processor function (required; internal only)
### @param version - Worker version (optional)
### @param options - BullMQ worker options (optional)
### @param infrastructure - Infrastructure config (optional)
### @param features - Feature flags (optional)
### @param datacenter - Datacenter placement config (optional)
### @returns Success response with worker name
###
POST {{WORKER_API_URL}}/api/workers/create
Content-Type: application/json

{
  "name": "advanced-test-mysql",
  "queueName": "advanced-queue",
  "processor": "app/Workers/AdvancEmailWorker.ts",
  "version": "1.0.0",
  "options": {
    "concurrency": 5,
    "limiter": {
      "max": 100,
      "duration": 60000
    }
  },
  "infrastructure": {
  "persistence": { "driver": "database"},
    "redis": {
      "env": true,
      "host": "REDIS_HOST",
      "port": "REDIS_PORT",
      "db": "REDIS_QUEUE_DB",
      "password": "REDIS_PASSWORD"
    },
    "deadLetterQueue": {
      "policy": "expire"
    },
    "compliance": {
      "config": {
        "retentionDays": 30
      }
    },
    "observability": {
      "enabled": true
    },
    "autoScaler": {
      "enabled": true,
      "minWorkers": 1,
      "maxWorkers": 5
    }
  },
  "features": {
    "clustering": false,
    "metrics": true,
    "autoScaling": true,
    "circuitBreaker": true,
    "deadLetterQueue": true,
    "resourceMonitoring": false,
    "compliance": true,
    "observability": true,
    "plugins": false,
    "versioning": true,
    "datacenterOrchestration": false
  },
  "datacenter": {
    "primaryRegion": "us-east-1",
    "secondaryRegions": ["us-west-2"],
    "affinityRules": {
      "preferLocal": true,
      "maxLatency": 120,
      "avoidRegions": ["ap-south-1"]
    }
  }
}


###  Get worker details
# Replace {{workerName}} with the worker name
###
### Get worker details
### @param workerName - Worker name (path)
### @returns Worker details
###
GET {{WORKER_API_URL}}/api/workers/{{workerName}}
Accept: application/json

###  Get worker status
###
### Get worker status
### @param workerName - Worker name (path)
### @returns Worker status
###
GET {{WORKER_API_URL}}/api/workers/{{workerName}}/status
Accept: application/json

###  Get worker metrics
###
### Get worker metrics
### @param workerName - Worker name (path)
### @returns Worker metrics
###
GET {{WORKER_API_URL}}/api/workers/{{workerName}}/metrics
Accept: application/json

###  Get worker health
###
### Get worker health
### @param workerName - Worker name (path)
### @returns Worker health
###
GET {{WORKER_API_URL}}/api/workers/{{workerName}}/health
Accept: application/json



###  Start worker
###
### Start a worker
### @param workerName - Worker name (path)
### @returns Success message
###
POST {{WORKER_API_URL}}/api/workers/{{workerName}}/start
Accept: application/json

###  Start worker (from DB persistence)
###
### Start a worker and auto-register from the DB persistence store
### @param workerName - Worker name (path)
### @param connection - DB connection name (query)
### @returns Success message
###
POST {{WORKER_API_URL}}/api/workers/{{workerName}}/start?storage=db&connection=mysql
Accept: application/json

###  Stop worker
###
### Stop a worker
### @param workerName - Worker name (path)
### @returns Success message
###
POST {{WORKER_API_URL}}/api/workers/{{workerName}}/stop
Accept: application/json

###  Restart worker
###
### Restart a worker
### @param workerName - Worker name (path)
### @returns Success message
###
POST {{WORKER_API_URL}}/api/workers/{{workerName}}/restart
Accept: application/json

###  Pause worker
###
### Pause a worker
### @param workerName - Worker name (path)
### @returns Success message
###
POST {{WORKER_API_URL}}/api/workers/{{workerName}}/pause
Accept: application/json

###  Resume worker
###
### Resume a worker
### @param workerName - Worker name (path)
### @returns Success message
###
POST {{WORKER_API_URL}}/api/workers/{{workerName}}/resume
Accept: application/json

###  Delete worker
###
### Delete a worker
### @param workerName - Worker name (path)
### @returns Success message
###
DELETE {{WORKER_API_URL}}/api/workers/{{workerName}}
Accept: application/json

###  Health monitoring - start
###
### Start health monitoring
### @param workerName - Worker name (path)
