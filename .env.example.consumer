# ZinTrust - Consumer Configuration (Containers)
# Value reference for worker-only deployments

# Base Configuration
NODE_ENV=production
APP_NAME=ZinTrust-Worker
RUNTIME_MODE=containers

# Worker & Queue Control
# Workers are enabled and auto-started here
WORKER_ENABLED=true
WORKER_AUTO_START=true
QUEUE_ENABLED=true

# Redis Configuration (Direct Connection)
USE_REDIS_PROXY=false
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=secret

# Database Driver Selection
# Options: postgres | mysql | sqlserver | sqlite | d1-proxy
DB_CONNECTION=postgres

# PostgreSQL Configuration
DB_HOST_POSTGRESQL=host.docker.internal
DB_PORT_POSTGRESQL=5432
DB_DATABASE_POSTGRESQL=zintrust
DB_USERNAME_POSTGRESQL=zintrust
DB_PASSWORD_POSTGRESQL=secret

# MySQL Configuration (if DB_CONNECTION=mysql)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=zintrust
DB_USERNAME=zintrust
DB_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootsecret

# SMTP Mail
MAIL_DRIVER=smtp
MAIL_CONNECTION=smtp
MAIL_HOST=host.docker.internal
MAIL_PORT=587
MAIL_SECURE=starttls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=ZinTrust

# SQL Server Configuration (if DB_CONNECTION=sqlserver)
DB_HOST_SQLSERVER=host.docker.internal
DB_PORT_SQLSERVER=1433
DB_DATABASE_SQLSERVER=zintrust
DB_USERNAME_SQLSERVER=sa
DB_PASSWORD_SQLSERVER=YourStrong@Passw0rd

# SQLite Configuration (if DB_CONNECTION=sqlite)
DB_DATABASE_SQLITE=/app/data/zintrust.db

# Cloudflare D1 Proxy Configuration (if DB_CONNECTION=d1-proxy)
D1_REMOTE_URL=https://your-d1-proxy.workers.dev
D1_DATABASE_ID=your-d1-database-id

# Scheduling (Node/Fargate only)
SCHEDULES_ENABLED=false
SCHEDULE_SHUTDOWN_TIMEOUT_MS=30000
SCHEDULE_OVERLAP_LOCK_TTL_MS=300000

# Schedule HTTP gateway (signed internal RPC)
SCHEDULE_HTTP_PROXY_PATH=/api/_sys/schedule/rpc
SCHEDULE_HTTP_PROXY_KEY_ID=
SCHEDULE_HTTP_PROXY_KEY=
SCHEDULE_HTTP_PROXY_MAX_SKEW_MS=60000
SCHEDULE_HTTP_PROXY_NONCE_TTL_MS=120000
SCHEDULE_HTTP_PROXY_MIDDLEWARE=

# Job tracking cleanup schedule (optional)
JOB_TRACKING_CLEANUP_ENABLED=false
JOB_TRACKING_CLEANUP_INTERVAL_MS=21600000
JOB_TRACKING_CLEANUP_RETENTION_DAYS=30
JOB_TRACKING_CLEANUP_BATCH_SIZE=5000
JOB_TRACKING_CLEANUP_MAX_BATCHES=1
JOB_TRACKING_CLEANUP_LOCK_PROVIDER=redis
