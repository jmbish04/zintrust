# ZinTrust - Producer Configuration (Cloudflare Workers)
# Value reference for producer-only deployments

# Base Configuration
NODE_ENV=production
APP_NAME=ZinTrust-Web
RUNTIME_MODE=cloudflare-workers

# Worker & Queue Control
# Workers are disabled in this environment (producers only)
WORKER_ENABLED=false
QUEUE_ENABLED=true

# Redis Configuration (Hyperdrive / Proxy / Http)
USE_REDIS_PROXY=true
REDIS_PROXY_URL=https://your-redis-proxy.example.com
# OR
ENABLE_CLOUDFLARE_SOCKETS=true
REDIS_HOST=
REDIS_PASSWORD=

# Database (D1 or HTTP Proxy)
DB_CONNECTION=d1
DB_DATABASE=zintrust_d1

# Scheduling (auto-start is Node/Fargate only)
SCHEDULE_SHUTDOWN_TIMEOUT_MS=30000
SCHEDULE_OVERLAP_LOCK_TTL_MS=300000

# Schedule HTTP gateway (signed internal RPC)
SCHEDULE_HTTP_PROXY_PATH=/api/_sys/schedule/rpc
SCHEDULE_HTTP_PROXY_KEY_ID=
SCHEDULE_HTTP_PROXY_KEY=
SCHEDULE_HTTP_PROXY_MAX_SKEW_MS=60000
SCHEDULE_HTTP_PROXY_NONCE_TTL_MS=120000
SCHEDULE_HTTP_PROXY_MIDDLEWARE=

# Job tracking cleanup schedule (optional; requires DB access)
JOB_TRACKING_CLEANUP_ENABLED=false
JOB_TRACKING_CLEANUP_INTERVAL_MS=21600000
JOB_TRACKING_CLEANUP_RETENTION_DAYS=30
JOB_TRACKING_CLEANUP_BATCH_SIZE=5000
JOB_TRACKING_CLEANUP_MAX_BATCHES=1
JOB_TRACKING_CLEANUP_LOCK_PROVIDER=redis
