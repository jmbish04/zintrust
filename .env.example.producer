# ZinTrust - Producer Configuration (Cloudflare Workers)
# Value reference for producer-only deployments

# Base Configuration
NODE_ENV=production
APP_NAME=ZinTrust-Web
RUNTIME_MODE=cloudflare-workers

# Worker & Queue Control
# Workers are disabled in this environment (producers only)
WORKER_ENABLED=false
QUEUE_ENABLED=true

# Redis Configuration (Hyperdrive / Proxy / Http)
USE_REDIS_PROXY=true
REDIS_PROXY_URL=https://your-redis-proxy.example.com
# OR
ENABLE_CLOUDFLARE_SOCKETS=true
REDIS_HOST=
REDIS_PASSWORD=

# Database (D1 or HTTP Proxy)
DB_CONNECTION=d1
DB_DATABASE=zintrust_d1
