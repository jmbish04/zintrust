    "@cloudflare/workers-types": "^4.20260217.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  }
