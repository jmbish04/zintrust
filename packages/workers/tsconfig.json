{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["es2023"],
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "composite": false,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@zintrust/queue-monitor": ["../queue-monitor/dist/index.d.ts"],
      "@zintrust/queue-redis": ["../queue-redis/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
