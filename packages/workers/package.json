{
  "name": "@zintrust/workers",
  "version": "0.1.31",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./HealthMonitor": {
      "types": "./dist/HealthMonitor.d.ts",
      "default": "./dist/HealthMonitor.js"
    },
    "./ResourceMonitor": {
      "types": "./dist/ResourceMonitor.d.ts",
      "default": "./dist/ResourceMonitor.js"
    },
    "./telemetry": {
      "types": "./telemetry/dist/index.d.ts",
      "default": "./telemetry/dist/index.js"
    },
    "./telemetry/*": {
      "types": "./telemetry/dist/*.d.ts",
      "default": "./telemetry/dist/*.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@zintrust/core": "file:../../dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "hot-shots": "^10.2.1",
    "ioredis": "^5.9.2",
    "ml.js": "^0.0.1",
    "prom-client": "^15.1.3",
    "simple-statistics": "^7.8.8"
  },
  "optionalDependencies": {
    "@zintrust/queue-monitor": "^0.1.27",
    "@zintrust/queue-redis": "^0.1.27"
  }
}
