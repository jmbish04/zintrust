{
  "name": "@zintrust/core",
  "version": "0.1.22",
  "description": "Production-grade TypeScript backend framework for JavaScript",
  "homepage": "https://zintrust.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZinTrust/ZinTrust.git"
  },
  "bugs": {
    "url": "https://github.com/ZinTrust/ZinTrust/issues"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "zintrust": "./bin/zintrust.ts",
    "zin": "./bin/zin.ts",
    "z": "./bin/z.ts",
    "zt": "./bin/zt.ts"
  },
  "files": [
    "bin",
    "src",
    "public",
    "index.js",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "core:link-dist": "mkdir -p node_modules/@zintrust && rm -rf node_modules/@zintrust/core && ln -s ../../dist node_modules/@zintrust/core && ls -la node_modules/@zintrust/core && cat node_modules/@zintrust/core/package.json | head -n 8",
    "build": "npm run clean && npm test && npm run templates:check && tsc && tsc-alias && node scripts/rewrite-dist-tsconfig-aliases.mjs && node scripts/fix-dist-esm-imports.mjs && node scripts/copy-cli-templates-to-dist.mjs && node scripts/copy-getting-started-to-dist-readme.mjs && node scripts/copy-docs-public-to-dist.mjs && node scripts/generate-dist-package.mjs",
    "build:ci": "export CI=true && npm run clean && npm run templates:check && tsc && tsc-alias && node scripts/rewrite-dist-tsconfig-aliases.mjs && node scripts/copy-docs-public-to-dist.mjs && node scripts/fix-dist-esm-imports.mjs && node scripts/generate-dist-package.mjs",
    "pro:build": "npm run clean && npm test && npm run templates:check && tsc && tsc-alias && node scripts/rewrite-dist-tsconfig-aliases.mjs && node scripts/fix-dist-esm-imports.mjs && node scripts/copy-docs-public-to-dist.mjs && node scripts/copy-cli-templates-to-dist.mjs && node scripts/copy-getting-started-to-dist-readme.mjs && node scripts/generate-dist-package.mjs",
    "watch": "tsc --watch --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:diff": "tsx dev/coverage-diff.ts",
    "coverage:patch": "sh scripts/coverage-patch.sh",
    "lint": "eslint .",
    "format": "prettier --write 'src/**/*.ts'",
    "dev": "./bin/z.ts s",
    "deploy": "cd docs-website && wrangler types && wrangler deploy --env ${WRANGLER_ENV:-production}",
    "templates:sync": "npm run templates:check && node -e \"console.log('templates:sync is disabled for now (no auto-updates). Update src/templates manually.');\"",
    "templates:check": "tsx src/scripts/TemplateImportsCheck.ts",
    "env:generate": "tsx src/scripts/GenerateEnvArtifacts.ts",
    "git-reload": "git rm -r --cached .  && git add .",
    "start": "node dist/src/bootstrap.js",
    "type-check": "tsc --noEmit",
    "test:sonar": "vitest run --coverage && tsx dev/sonar-scan.ts",
    "sonarqube": "tsx dev/sonar-scan.ts",
    "sonarqube:setup": "node dev/sonarqube-setup.js",
    "sonarcloud:issues": "tsx dev/sonarcloud-issues.ts",
    "sonarcloud:issues:low": "tsx dev/sonarcloud-issues.ts --low --open",
    "sonarcloud:issues:measures": "tsx dev/sonarcloud-issues.ts --measures",
    "sonarcloud:check": "bash dev/sonarcloud-check.sh",
    "docker:build": "docker build -t zintrust:latest .",
    "docker:build:prod": "docker build -t zintrust:latest --target runtime .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:stop": "docker-compose stop",
    "docker:logs": "docker-compose logs -f app",
    "docker:shell": "docker-compose run --rm app sh",
    "docker:test": "docker-compose exec app npm test",
    "docker:migrate": "docker-compose exec app node dist/bootstrap.js migrate",
    "microservices:generate": "tsx bin/zintrust-microservices.ts generate",
    "microservices:bundle": "tsx bin/zintrust-microservices.ts bundle",
    "microservices:docker": "tsx bin/zintrust-microservices.ts docker",
    "microservices:discover": "tsx bin/zintrust-microservices.ts discover",
    "microservices:status": "tsx bin/zintrust-microservices.ts status",
    "microservices:health": "tsx bin/zintrust-microservices.ts health",
    "docs:dev:vue": "cd docs-website/vue && npm run dev",
    "docs:dev": "node scripts/docs-website-dev.mjs --port 7030",
    "docs:build:vue": "mkdir -p docs-website/vue/public && cp docs-website/zintrust.svg docs-website/vue/public/ && cp docs/*.md docs-website/vue/ && cd docs-website/vue && npm run build && cp -R .vitepress/dist/* ../public/",
    "docs:build:portal": "node scripts/docs-build-portal.mjs",
    "docs:build:all": "rm -rf docs-website/public && npm run docs:build:portal && npm run docs:build:vue",
    "docs:brand:png": "node scripts/convert-brand-svgs-to-png.mjs --input docs-website/brand --max 2048",
    "dbl": "npm run docs:build:all",
    "zintrust:prepare": "tsx bin/zintrust.ts prepare",
    "ecommerce:up": "cd services/ecommerce && docker-compose up -d",
    "ecommerce:down": "cd services/ecommerce && docker-compose down",
    "ecommerce:logs": "cd services/ecommerce && docker-compose logs -f",
    "cleanup:github-actions": "bash ./dev/cleanup-github-actions.sh",
    "commemtout": "bash ./scripts/disable-plugins-import.sh",
    "duplication:check": "node scripts/ci/duplication-check.mjs",
    "prepare": "node -e \"const omit=(process.env.npm_config_omit||'').split(',').map(s=>s.trim()).filter(Boolean); const skip=process.env.NODE_ENV==='production'||process.env.CI==='true'||process.env.CI==='1'||omit.includes('dev'); process.exit(skip?0:1)\" || husky",
    "postinstall": "node -e \"process.exit(0)\"",
    "check-up": "npx npm-check-updates",
    "pub": "npm run pro:build && cd dist && npm publish",
    "pub:ci": "cd dist && npm publish --access public",
    "rebuild:bcrypt": "npm rebuild bcrypt",
    "rebuild:native": "npm rebuild bcrypt better-sqlite3",
    "b:push": "npm run lint --max-warnings=0",
    "bg": "npm install -g /opt/homebrew/var/www/Sites/zintrust/dist",
    "release:sync-versions": "node scripts/release/sync-package-versions.mjs",
    "release:publish-packages": "node scripts/release/publish-packages.mjs",
    "release:publish-all": "npm run release:sync-versions && npm run release:publish-packages"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "keywords": [
    "framework",
    "typescript",
    "backend",
    "orm",
    "query-builder",
    "rest-api",
    "react",
    "react-api",
    "vue",
    "vue-api",
    "symfony",
    "laravel"
  ],
  "author": "Zintrust Team",
  "license": "MIT",
  "overrides": {
    "node-forge": "1.3.3",
    "cross-spawn": "^7.0.5",
    "glob": "^11.1.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bg": "^1.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "inquirer": "^13.2.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.1",
    "@faker-js/faker": "^10.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.6",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-v8": "^4.0.16",
    "better-sqlite3": "^12.6.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prom-client": "^15.1.3",
    "sonarqube-scanner": "^4.3.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  }
}
